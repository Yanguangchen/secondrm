# Copy this file to `.env.local` (git-ignored) and fill in real values.
# Required by api/form/submit.js when running `vercel dev` or deploying to Vercel.
# Do NOT commit a populated copy.

# Server-side reCAPTCHA secret matching the site key embedded in register.html.
# Get this from the Google reCAPTCHA admin console for the same site as the key.
RECAPTCHA_SECRET=

# Full Firebase service-account JSON, as a single line.
# Generate via Firebase Console → Project Settings → Service Accounts → "Generate new private key".
# IMPORTANT: it must be a JSON STRING, not a path. Newlines inside `private_key`
# may be escaped (`\n`) or literal — api/form/submit.js normalises both.
#
# Example (truncated):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"secondrm-dev","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@secondrm-dev.iam.gserviceaccount.com","client_id":"..."}
#
# Use a NON-PRODUCTION Firebase project for local dev. The Admin SDK bypasses
# Firestore rules; pointing this at production will write real submissions.
FIREBASE_SERVICE_ACCOUNT=
